{
  "name": "github-stats",
  "type": "module",
  "scripts": {
    "build": "bun --bun dressed build",
    "checks": "tsc --noEmit && bun biome check --write",
    "register": "bun run build -r && bun start",
    "start": "bun .dressed"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "abseil": "^0.4.1",
    "dressed": "^2.0.0-rc.3",
    "mustache": "^4.2.0",
    "vercel": "^54.20.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@dressed/framework": "^0.5.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.1.0"
  },
  "packageManager": "bun@1.3.14"
}
