{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "rewriteRelativeImportExtensions": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true,
    "types": ["node"]
  }
}
